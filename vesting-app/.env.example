# Copy to .env for local development.
# For GitHub Actions, add VITE_* values as repository variables:
# Settings → Secrets and variables → Actions → Variables tab

# ── Contract addresses (Gnosis Chiado testnet) ──────────────────────────────
VITE_VESTING_POOL_MANAGER=0x10A27767cdf0a01C27c999a5595838e1E2825423
VITE_TOKEN_ADDRESS=0xBD13202B16408EE2cD0a0b57Beae0C97a797DF7c

# ── GitHub Pages base path ───────────────────────────────────────────────────
# For a project page (username.github.io/REPO_NAME) set to '/REPO_NAME/'
# Leave empty for user page (username.github.io) or custom domain.
VITE_BASE_URL=

# ── WalletConnect (optional) ─────────────────────────────────────────────────
VITE_WALLETCONNECT_PROJECT_ID=

# ── Deployer (local hardhat deploy only — NEVER commit this!) ─────────────
DEPLOYER_PRIVATE_KEY=
DEPLOYER_ADDRESS=
